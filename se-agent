#!/usr/bin/env python3
"""
se-agent CLI
=============
Command-line interface for the SE-Agentic-Evaluator Agent.

Implements the Turtle Pattern from the methodology:
  se-agent run "tasca"                  → nova sessió
  se-agent run <session-id> "tasca"     → continua sessió
  se-agent --list-sessions              → llista sessions
  se-agent --help                       → ajuda

Usage:
  se-agent run "avalua aquest document amb la rúbrica X"
  se-agent run abc123 "genera l'informe final"
  se-agent --list-sessions
"""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
from typing import Optional

from dotenv import load_dotenv
load_dotenv()

from core.agent.agent import Agent
from core.agent.session_store import SessionStore


def cmd_run(args: argparse.Namespace) -> None:
    """Execute a task (new or existing session)."""
    agent = Agent()
    
    # Determine if this is a new session or continuation
    session_id = args.session_id if hasattr(args, 'session_id') and args.session_id else None
    message = args.message
    
    # Run the agent
    response, session_id = agent.run(message, session_id)
    
    # Output structured result
    if args.json:
        result = {
            "session_id": session_id,
            "response": response,
        }
        print(json.dumps(result, ensure_ascii=False, indent=2))
    else:
        print(f"\n📝 Session ID: {session_id}")
        print(f"\n💬 Response:\n{response}")


def cmd_list_sessions(args: argparse.Namespace) -> None:
    """List all available sessions."""
    store = SessionStore()
    sessions = store.list_sessions()
    
    if not sessions:
        print("No hi ha sessions guardades.")
        return
    
    print(f"📚 Sessions disponibles ({len(sessions)}):\n")
    for session_id in sessions:
        messages = store.load(session_id)
        first_msg = messages[0]["content"][:50] if messages else "(buida)"
        print(f"  • {session_id}")
        print(f"    Primer missatge: {first_msg}...")
        print(f"    Missatges: {len(messages)}")
        print()


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="se-agent",
        description="SE-Agentic-Evaluator Agent CLI (Turtle Pattern)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Exemples:
  se-agent run "avalua documents/test.docx amb rubriques/hito1.md"
  se-agent run --session-id abc123-def456 "genera l'informe final"
  se-agent --list-sessions
        """,
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Comandes disponibles")
    
    run_parser = subparsers.add_parser("run", help="Executa una tasca")
    run_parser.add_argument("message", help="Missatge o tasca a executar")
    run_parser.add_argument("--session-id", help="ID de sessió existent (opcional)")
    run_parser.add_argument("--json", action="store_true", help="Sortida en format JSON")
    run_parser.set_defaults(func=cmd_run)
    
    list_parser = subparsers.add_parser("list-sessions", help="Llista sessions guardades")
    list_parser.set_defaults(func=cmd_list_sessions)
    
    args = parser.parse_args()
    
    if args.command is None:
        parser.print_help()
        sys.exit(1)
    
    if hasattr(args, "func"):
        args.func(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
