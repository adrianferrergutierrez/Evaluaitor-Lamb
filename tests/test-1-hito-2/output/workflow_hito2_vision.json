{
  "version": "1.0",
  "name": "workflow_hito2_eval",
  "description": "Evaluación de documento académico (Memoria técnica, Diagrama de clases y Glosario) contra rúbrica hito2.",
  "metadata": {
    "rubric_id": "hito2",
    "created_at": "2026-05-22T12:30:04.726903",
    "version": "1.0"
  },
  "variables": {
    "input_docx": "path/to/document.docx",
    "input_rubric": "path/to/rubric.yaml",
    "output_dir": "path/to/output"
  },
  "steps": [
    {
      "id": "step_extract_docx",
      "tool": "docx_extract",
      "description": "Convertir documento DOCX a Markdown para procesamiento.",
      "params": {
        "input": "${input_docx}",
        "output_dir": "${output_dir}/extracted"
      },
      "output": {
        "contents_md": "markdown_path",
        "images": "image_count"
      },
      "on_error": "abort"
    },
    {
      "id": "step_describe_diagrams",
      "tool": "describe_diagrams",
      "description": "Analizar imágenes del diagrama de clases y generar descripciones textuales para el evaluador.",
      "params": {
        "document_path": "${step_extract_docx.result.contents_md}",
        "model": "qwen-vl-max"
      },
      "output": {
        "updated_md": "updated_markdown_path",
        "descriptions_count": "count"
      },
      "on_error": "abort"
    },
    {
      "id": "step_evaluate",
      "tool": "criterion_evaluator",
      "description": "Evaluar criterios de la rúbrica (memoria, diagrama, glosario) sobre el documento procesado.",
      "params": {
        "document": "${step_describe_diagrams.result.updated_md}",
        "config": "${input_rubric}",
        "full": false,
        "output_dir": "${output_dir}/evaluation"
      },
      "output": {
        "scores": "scores_dict",
        "output_dir": "eval_output_dir"
      },
      "on_error": "abort"
    },
    {
      "id": "step_grade",
      "tool": "grader",
      "description": "Calcular la calificación final ponderada según los pesos de la rúbrica.",
      "params": {
        "scores": "${step_evaluate.result.scores}",
        "config": "${input_rubric}"
      },
      "output": {
        "weighted_final": "final_grade",
        "mean_xbar": "mean_score",
        "performance_level": "performance_label"
      },
      "on_error": "abort"
    },
    {
      "id": "step_report",
      "tool": "report_generator",
      "description": "Generar informe final de evaluación consolidado.",
      "params": {
        "document": "${step_describe_diagrams.result.updated_md}",
        "eval_dir": "${step_evaluate.result.output_dir}",
        "config": "${input_rubric}",
        "scores": "${step_evaluate.result.scores}",
        "output": "${output_dir}/final_report.md"
      },
      "output": {
        "report_path": "report_file_path"
      },
      "on_error": "abort"
    }
  ]
}