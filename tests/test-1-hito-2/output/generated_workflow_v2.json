{
  "version": "1.0",
  "name": "workflow_eval_hito2",
  "description": "Evaluación de documento académico contra rúbrica de Hito 2 (Memoria técnica, Diagrama de clases, Glosario)",
  "variables": {
    "input_docx": "tests/test-1-hito-2/A1.1 Memoria trabajo final (2).docx",
    "input_rubric": "configs/rubric_hito2.yaml",
    "output_dir": "tests/test-1-hito-2/output"
  },
  "steps": [
    {
      "id": "step_extract_doc",
      "tool": "docx_extract",
      "description": "Convertir DOCX a Markdown y extraer imágenes para evaluación multimodal",
      "params": {
        "input": "${input_docx}",
        "output_dir": "${output_dir}"
      },
      "output": {
        "document_md": "${step_extract_doc.result.contents_md}",
        "images": "${step_extract_doc.result.images}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_evaluate",
      "tool": "criterion_evaluator",
      "description": "Evaluar criterios de la rúbrica sobre el documento extraído",
      "params": {
        "document": "${step_extract_doc.result.contents_md}",
        "config": "${input_rubric}",
        "full": false,
        "output_dir": "${output_dir}/eval"
      },
      "output": {
        "scores": "${step_evaluate.result.scores}",
        "eval_dir": "${step_evaluate.result.output_dir}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_grade",
      "tool": "grader",
      "description": "Calcular la calificación final ponderada",
      "params": {
        "scores": "${step_evaluate.result.scores}",
        "config": "${input_rubric}"
      },
      "output": {
        "final_grade": "${step_grade.result.weighted_final}",
        "mean": "${step_grade.result.mean_xbar}",
        "level": "${step_grade.result.performance_level}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_report",
      "tool": "report_generator",
      "description": "Generar informe final de evaluación",
      "params": {
        "document": "${step_extract_doc.result.contents_md}",
        "eval_dir": "${output_dir}/eval",
        "config": "${input_rubric}",
        "scores": "${step_evaluate.result.scores}",
        "output": "${output_dir}/report.md"
      },
      "output": {
        "report_path": "${step_report.result.report_path}"
      },
      "on_error": "skip"
    }
  ]
}