{
  "version": "1.0",
  "name": "workflow_hito2_eval",
  "description": "Evaluación del Hito 2 centrada en diagrama de clases, glosario y memoria técnica con soporte multimodal.",
  "variables": {
    "input_docx": "tests/test-1-hito-2/A1.1 Memoria trabajo final (2).docx",
    "input_rubric": "configs/rubric_hito2.yaml",
    "output_dir": "tests/test-1-hito-2/output"
  },
  "steps": [
    {
      "id": "step_extract_docx",
      "tool": "docx_extract",
      "description": "Convertir documento DOCX a Markdown y extraer imágenes para evaluación multimodal del diagrama.",
      "params": {
        "input": "${input_docx}",
        "output_dir": "${output_dir}/extracted"
      },
      "output": {
        "document_md": "${step_extract_docx.result.contents_md}",
        "images": "${step_extract_docx.result.images}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_evaluate",
      "tool": "criterion_evaluator",
      "description": "Evaluar criterios de la rúbrica (memoria, diagrama, glosario) contra el documento extraído.",
      "params": {
        "document": "${step_extract_docx.output.contents_md}",
        "config": "${input_rubric}",
        "full": true,
        "output_dir": "${output_dir}/eval"
      },
      "output": {
        "scores": "${step_evaluate.result.scores}",
        "eval_dir": "${step_evaluate.result.output_dir}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_grade",
      "tool": "grader",
      "description": "Calcular la calificación final ponderada basada en los pesos de la rúbrica.",
      "params": {
        "scores": "${step_evaluate.result.scores}",
        "config": "${input_rubric}"
      },
      "output": {
        "final_grade": "${step_grade.result.weighted_final}",
        "mean": "${step_grade.result.mean_xbar}",
        "level": "${step_grade.result.performance_level}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_report",
      "tool": "report_generator",
      "description": "Generar informe final de evaluación consolidado.",
      "params": {
        "document": "${step_extract_docx.output.contents_md}",
        "eval_dir": "${step_evaluate.output.output_dir}",
        "config": "${input_rubric}",
        "scores": "${step_evaluate.output.scores}",
        "output": "${output_dir}/report.md"
      },
      "output": {
        "report_path": "${step_report.result.report_path}"
      },
      "on_error": "skip"
    }
  ]
}